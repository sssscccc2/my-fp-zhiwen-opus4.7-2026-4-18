[Unit]
Description=Fingerprint Browser Auth Server
After=network.target
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/fp-browser-auth
ExecStart=/usr/bin/node /opt/fp-browser-auth/server.js
Restart=always
RestartSec=3
StandardOutput=append:/var/log/fp-auth-server.log
StandardError=append:/var/log/fp-auth-server.log
# Production-ish: don't crash-loop forever
StartLimitIntervalSec=60
StartLimitBurst=10

[Install]
WantedBy=multi-user.target
